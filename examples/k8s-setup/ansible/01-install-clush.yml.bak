---
# Playbook: Install ClusterShell (clush) on all nodes
# Usage: ansible-playbook -i inventory.ini 01-install-clush.yml

- name: Install ClusterShell on all nodes
  hosts: all
  become: yes
  gather_facts: yes

  tasks:
    - name: Update apt cache (Debian/Ubuntu)
      apt:
        update_cache: yes
        cache_valid_time: 3600
      when: ansible_os_family == "Debian"

    - name: Install ClusterShell on Debian/Ubuntu
      apt:
        name:
          - clustershell
          - python3-clustershell
        state: present
      when: ansible_os_family == "Debian"

    - name: Install EPEL repository (RHEL/CentOS)
      yum:
        name: epel-release
        state: present
      when: ansible_os_family == "RedHat"

    - name: Install ClusterShell on RHEL/CentOS
      yum:
        name:
          - clustershell
        state: present
      when: ansible_os_family == "RedHat"

    - name: Create ClusterShell groups directory
      file:
        path: /etc/clustershell/groups.d
        state: directory
        mode: '0755'

    - name: Configure ClusterShell groups
      copy:
        dest: /etc/clustershell/groups.d/local.cfg
        content: |
          # Kubernetes cluster groups
          all: master,worker1
          masters: master
          workers: worker1
          k8s: @masters,@workers

          # Node aliases
          master: 10.143.2.65
          worker1: 10.143.2.69
        mode: '0644'

    - name: Configure ClusterShell defaults
      copy:
        dest: /etc/clustershell/clush.conf
        content: |
          [Main]
          fanout: 64
          connect_timeout: 15
          command_timeout: 0
          color: auto
          fd_max: 16384
          history_size: 100
          node_count: yes
          verbosity: 1

          [SSH]
          ssh_user: vastdata
          ssh_path: /usr/bin/ssh
          ssh_options: -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null
        mode: '0644'

    - name: Verify clush installation
      command: clush --version
      register: clush_version
      changed_when: false

    - name: Display clush version
      debug:
        msg: "ClusterShell version: {{ clush_version.stdout }}"

    - name: Test clush connectivity (from master only)
      command: clush -g all 'hostname'
      register: clush_test
      when: inventory_hostname == 'master'
      ignore_errors: yes
      changed_when: false

    - name: Display clush test result
      debug:
        msg: "{{ clush_test.stdout_lines }}"
      when: inventory_hostname == 'master' and clush_test is defined
