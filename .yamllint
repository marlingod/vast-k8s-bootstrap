---
extends: default

rules:
  line-length:
    max: 160
    level: warning
  truthy:
    allowed-values: ["true", "false", "yes", "no"]
  comments:
    min-spaces-from-content: 1
  braces:
    max-spaces-inside: 1
  octal-values:
    forbid-implicit-octal: true
    forbid-explicit-octal: true
  comments-indentation: false

ignore: |
  collections/ansible_collections/community/
  collections/ansible_collections/kubernetes/
  collections/ansible_collections/ansible/
  collections/ansible_collections/*.info/
  collections/ansible_collections/vast/kubernetes/galaxy.yml
  collections/ansible_collections/vast/kubernetes/roles/*/files/
  .cache/
